# Copy this file to .env and fill in the values you want to override.
# All values shown here are the defaults — you only need to set what you change.

# ── Host port ABR listens on ─────────────────────────────────────────────────
ABR_PORT=8009

# ── Sub-path when sitting behind a reverse proxy ─────────────────────────────
# Leave blank if ABR is served at the root (e.g. http://nas:8000/)
# Set to "/abr" (no trailing slash) if proxied at http://nas/abr
ABR_BASE_URL=

# ── Audible region for metadata ───────────────────────────────────────────────
# us | ca | uk | au | fr | de | jp | it | in | es | br
ABR_DEFAULT_REGION=us

# ── Logging ───────────────────────────────────────────────────────────────────
ABR_LOG_LEVEL=INFO

# ── Trusted reverse-proxy IPs (for X-Forwarded-For) ──────────────────────────
# Set to * if your reverse proxy is in the same Docker network as ABR.
ABR_FORWARDED_ALLOW_IPS=127.0.0.1

# ── Auto-create admin account on first boot (optional) ───────────────────────
ABR_INIT_ROOT_USERNAME=
ABR_INIT_ROOT_PASSWORD=

# ── SQLite path (relative to /config volume, or absolute) ────────────────────
ABR_DB__SQLITE_PATH=db.sqlite

# ── PostgreSQL (only needed if you uncomment postgres in compose.yaml) ────────
POSTGRES_USER=abr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=audiobookrequest
