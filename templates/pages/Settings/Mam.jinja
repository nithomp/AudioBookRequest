{#def
    user: DetailedUser,
    mam_session_id_set: bool,
    ttl_minutes: int,
    trusted_visible: bool,
#}

<SettingsLayout user={{ user }} page="mam" title="Settings - MaM">

<div class="flex flex-col gap-4">
    <h2 class="text-lg">MyAnonamouse (MaM) Freeleech</h2>

    {# ── Session ID status ── #}
    <div class="alert {% if mam_session_id_set %}alert-success{% else %}alert-warning{% endif %}">
        <span>
            {% if mam_session_id_set %}
                MaM session ID is configured. The freeleech page is ready to use.
            {% else %}
                MaM session ID is not set. Go to
                <a href="{{ base_url }}/settings/indexers" class="underline font-semibold">
                    Settings &rsaquo; Indexers &rsaquo; MyAnonamouse
                </a>
                and enter your MAM Session ID there. The freeleech page uses the same credential.
            {% endif %}
        </span>
    </div>

    <hr class="my-2 border-base-200" />

    {# ── Cache TTL ── #}
    <label for="mam-ttl">Freeleech cache TTL (minutes)</label>
    <form class="join w-full"
          hx-put="{{ base_url }}/settings/mam/hx-ttl"
          hx-disabled-elt="#mam-ttl-btn">
        <input id="mam-ttl"
               name="ttl_minutes"
               type="number"
               value="{{ ttl_minutes }}"
               min="1"
               max="10080"
               class="input join-item w-32"
               required />
        <button id="mam-ttl-btn" class="join-item btn">Update</button>
    </form>
    <p class="text-xs opacity-60">
        How long to cache MaM freeleech results before re-fetching (default: 10080 minutes = 7 days).
        Current: {{ (ttl_minutes // 1440) }}d {{ ((ttl_minutes % 1440) // 60) }}h {{ (ttl_minutes % 60) }}m.
    </p>

    <hr class="my-2 border-base-200" />

    {# ── Visibility toggle ── #}
    <div class="flex flex-col gap-1">
        <h3 class="font-semibold">Freeleech page visibility</h3>
        <form hx-post="{{ base_url }}/settings/mam/hx-trusted-toggle"
              hx-disabled-elt="#trusted-toggle-btn">
            <label class="label cursor-pointer justify-start gap-4">
                <input type="checkbox"
                       name="trusted_visible"
                       value="true"
                       class="toggle toggle-primary"
                       {% if trusted_visible %}checked{% endif %}
                       onchange="this.form.requestSubmit()" />
                <span class="label-text">Allow Trusted users to see the Freeleech page</span>
            </label>
            <button id="trusted-toggle-btn" class="hidden" type="submit"></button>
        </form>
        <p class="text-xs opacity-60">
            When disabled, only Admins can access <code>/freeleech</code>.
        </p>
    </div>

    <hr class="my-2 border-base-200" />

    <a href="{{ base_url }}/freeleech" class="btn btn-primary self-start">
        Open Freeleech Page
    </a>
</div>

</SettingsLayout>
